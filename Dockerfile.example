ARG NEXTCLOUD_BASE_TAG=33-apache
FROM nextcloud:${NEXTCLOUD_BASE_TAG}

# Copy provider to both source tree and runtime path.
# /usr/src/nextcloud is used by the official entrypoint on first install.
# /var/www/html is the live path when it is a bind-mounted volume.
COPY ClipStudio.php /usr/src/nextcloud/lib/private/Preview/ClipStudio.php
COPY ClipStudio.php /var/www/html/lib/private/Preview/ClipStudio.php

COPY patch_preview_manager_clip.php /tmp/patch_preview_manager_clip.php
RUN php /tmp/patch_preview_manager_clip.php && rm -f /tmp/patch_preview_manager_clip.php
